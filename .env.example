# ============================================================
# ALHIKMAH ATTENDANCE WEB - ENVIRONMENT TEMPLATE
# Salin file ini menjadi .env.development (untuk lokal) 
# atau .env.production (untuk production) lalu sesuaikan nilainya.
# ============================================================

# --- API Configuration ---
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_API_TIMEOUT=30000

# --- Application Configuration ---
VITE_APP_NAME=Alhikmah Attendance System
VITE_APP_VERSION=0.1.0

# --- Authentication ---
VITE_JWT_TOKEN_KEY=auth_token

# --- QR Code Settings ---
VITE_QR_CODE_SIZE=300
VITE_QR_CODE_ERROR_LEVEL=H

# --- Pagination ---
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# --- Report Settings ---
VITE_REPORT_EXPORT_FORMATS=pdf,excel,csv
VITE_DEFAULT_TIMEZONE=Asia/Jakarta

# --- Feature Flags ---
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_QR_SCANNER=true
VITE_ENABLE_ANALYTICS=false
VITE_SENTRY_DSN=
